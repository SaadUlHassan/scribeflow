# --- API ---
# Static API key required in the X-API-Key header on all /v1 endpoints
API_KEY=dev-secret-key
# Port the NestJS API listens on (also mapped in docker-compose.yml)
PORT=3000
# Maximum upload size in megabytes (uploads over this return 413)
MAX_UPLOAD_MB=200

# --- Shared infrastructure ---
# Postgres connection string (service hostname from docker-compose network)
DATABASE_URL=postgres://scribeflow:scribeflow@postgres:5432/scribeflow
# RabbitMQ connection string (service hostname from docker-compose network)
RABBITMQ_URL=amqp://scribeflow:scribeflow@rabbitmq:5672/
# Directory on the shared volume where audio files are stored
AUDIO_DIR=/data/audio

# --- Postgres container bootstrap ---
POSTGRES_USER=scribeflow
POSTGRES_PASSWORD=scribeflow
POSTGRES_DB=scribeflow

# --- RabbitMQ container bootstrap ---
RABBITMQ_DEFAULT_USER=scribeflow
RABBITMQ_DEFAULT_PASS=scribeflow

# --- Web UI ---
# The web service proxies API calls server-side using API_KEY (above) and the
# in-network API_URL set in docker-compose.yml; no extra variables needed here.

# --- Worker / transcription ---
# faster-whisper model name (must match the model pre-downloaded in worker/Dockerfile)
WHISPER_MODEL=small
# Files longer than this (seconds) are processed in chunks
CHUNK_THRESHOLD_SEC=600
# Chunk length in seconds for long-file processing
CHUNK_SEC=300
